# ==============================================================================
# banana-slides — 腾讯云生产环境配置模板
# 使用方法：cp deploy/.env.tencent deploy/.env，然后填写 REQUIRED 标记的项
# deploy/.env 已被 gitignore，绝对不要提交到 git
# ==============================================================================

# ------------------------------------------------------------------------------
# AI 服务商 — REQUIRED: 选择一个并填入 API Key
# ------------------------------------------------------------------------------
# 可选值: gemini | openai | anthropic
# 部署后也可在界面的设置页面修改
AI_PROVIDER_FORMAT=openai

# Gemini (Google GenAI)
GOOGLE_API_KEY=FILL_IN_YOUR_KEY
GOOGLE_API_BASE=https://generativelanguage.googleapis.com
GENAI_TIMEOUT=300.0
GENAI_MAX_RETRIES=2

# OpenAI 兼容接口（也适用于 DeepSeek、Qwen 等国内模型）
OPENAI_API_KEY=FILL_IN_YOUR_KEY
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_TIMEOUT=300.0
OPENAI_MAX_RETRIES=2

# Anthropic (Claude)
ANTHROPIC_API_KEY=FILL_IN_YOUR_KEY
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=8192

# 国内厂商 API Keys（只填你实际使用的）
DOUBAO_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
SILICONFLOW_API_KEY=
SENSENOVA_API_KEY=
MINIMAX_API_KEY=

# ------------------------------------------------------------------------------
# Flask — REQUIRED: 首次部署前必须修改 SECRET_KEY
# 生成命令: python3 -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------------------------
FLASK_ENV=production
LOG_LEVEL=INFO
SECRET_KEY=FILL_IN_RANDOM_SECRET_KEY
BACKEND_PORT=5000

# ------------------------------------------------------------------------------
# CORS — 暂无域名先用 *，有域名后改为具体地址
# 多个地址用逗号分隔，例如: https://example.com,http://1.2.3.4
# ------------------------------------------------------------------------------
CORS_ORIGINS=*

# ------------------------------------------------------------------------------
# 并发配置 — 针对 2GB 内存服务器调优
# ------------------------------------------------------------------------------
MAX_DESCRIPTION_WORKERS=3
MAX_IMAGE_WORKERS=4

# ------------------------------------------------------------------------------
# 可选服务
# ------------------------------------------------------------------------------
MINERU_TOKEN=
MINERU_API_BASE=https://mineru.net
BAIDU_API_KEY=

# 访问口令（留空则不启用，建议生产环境设置）
# ACCESS_CODE=your-access-code-here

# 输出语言: zh | en | ja | auto
OUTPUT_LANGUAGE=zh

# ------------------------------------------------------------------------------
# 构建时镜像源（传给 docker-compose build args，非 Flask 运行时变量）
# 腾讯云服务器已预填国内镜像源
# ------------------------------------------------------------------------------
DOCKER_REGISTRY=docker.1ms.run/
GHCR_REGISTRY=ghcr.nju.edu.cn/
APT_MIRROR=mirrors.tencent.com
PYPI_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
NPM_REGISTRY=https://registry.npmmirror.com/
